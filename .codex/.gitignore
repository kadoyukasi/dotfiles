# Ignore everything by default (runtime/state/secrets/logs/cache)
*

# Track managed Codex dotfiles
!.gitignore
!AGENTS.md
!config.toml
!hooks.json
!hooks/
!hooks/common.py
!hooks/session_start.py
!hooks/pre_tool_use.py
!hooks/permission_request.py
!hooks/user_prompt_submit.py

# Track user-authored policy and custom skill
!rules/
!skills/
!skills/distill/
!skills/distill/SKILL.md
