#!/bin/bash

set -euo pipefail

# Codex writes machine-local approval and cache state into the user config.
# Keep that state in the working tree, but never store it in Git blobs.
awk '
function is_table(line) {
    return line ~ /^\[\[?[^]]+\]\]?[[:space:]]*(#.*)?$/
}

function is_machine_state(line) {
    return line ~ /^\[projects\./ || \
        line ~ /^\[hooks\.state(\]|\.)/ || \
        line ~ /^\[marketplaces\./
}

function has_machine_home_path(line) {
    return line ~ /\/(Users|home)\/[^\/]+\// || \
        line ~ /[A-Za-z]:[\\\/]Users[\\\/][^\\\/]+[\\\/]/
}

function is_machine_assignment(line) {
    return line ~ /^(notify|NODE_REPL_TRUSTED_CODE_PATHS|CODEX_HOME)[[:space:]]*=/ && \
        has_machine_home_path(line)
}

{
    if (is_table($0)) {
        skip = is_machine_state($0)
    }

    if (!skip && !is_machine_assignment($0)) {
        print
    }
}
'
