#!/bin/bash

set -euo pipefail

# Scan staged content to prevent accidental secret commits.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMRT)

if [ -z "$STAGED_FILES" ]; then
    echo "[secret-check] skipped: no staged files"
    exit 0
fi

FILE_COUNT=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')
echo "[secret-check] scanning $FILE_COUNT staged file(s)..."

SENSITIVE_PATH_PATTERNS=(
    '(^|/)auth\.json$'
    '(^|/)\.env(\.|$)'
    '(^|/)id_(rsa|dsa|ecdsa|ed25519)$'
    '\.pem$'
    '\.key$'
    '\.p12$'
    '\.pfx$'
    '\.sqlite([-.].*)?$'
    '\.db([-.].*)?$'
)

SENSITIVE_CONTENT_PATTERNS=(
    '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'
    'AKIA[0-9A-Z]{16}'
    'ghp_[A-Za-z0-9]{36}'
    'github_pat_[A-Za-z0-9_]{82,}'
    'xox[baprs]-[A-Za-z0-9-]{10,}'
    'AIza[0-9A-Za-z\\-_]{35}'
    'sk_live_[0-9A-Za-z]{20,}'
    '(api[_-]?key|access[_-]?token|secret|password)[[:space:]]*[:=][[:space:]]*["'"'"']?[A-Za-z0-9_./+\\=-]{12,}'
)

SENSITIVE_CONTENT_PATTERN=$(printf '%s|' "${SENSITIVE_CONTENT_PATTERNS[@]}")
SENSITIVE_CONTENT_PATTERN="${SENSITIVE_CONTENT_PATTERN%|}"

IGNORE_LINE_MARKER='secret-check-ignore-line'
IGNORE_NEXT_LINE_MARKER='secret-check-ignore-next-line'
IGNORE_FILE_NAMES=(
    '.secret-check-ignore'
    '.git-secret-check-ignore'
)
IGNORE_FILE_PATHS=()

TMPFILE="$(mktemp)"
trap 'rm -f "$TMPFILE"' EXIT

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -n "$repo_root" ]; then
    for ignore_filename in "${IGNORE_FILE_NAMES[@]}"; do
        ignore_path="$repo_root/$ignore_filename"
        if [ -f "$ignore_path" ]; then
            while IFS= read -r line; do
                line="${line%%#*}"
                line="$(printf '%s' "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
                [ -n "$line" ] && IGNORE_FILE_PATHS+=("$line")
            done < "$ignore_path"
        fi
    done
fi

violations=0

while IFS= read -r path; do
    [ -z "$path" ] && continue

    # Skip files matched by ignore file patterns.
    if [ "${#IGNORE_FILE_PATHS[@]}" -gt 0 ]; then
        for ignore_pattern in "${IGNORE_FILE_PATHS[@]}"; do
            case "$path" in
                $ignore_pattern)
                    echo "[secret-check] ignored by ignore file: $path"
                    continue 2
                    ;;
            esac
        done
    fi

    for pattern in "${SENSITIVE_PATH_PATTERNS[@]}"; do
        if echo "$path" | grep -Eq -- "$pattern"; then
            echo "[secret-check] blocked by filename/path pattern: $path"
            violations=1
            break
        fi
    done

    # Read staged blob, not working tree file. Avoid storing null bytes in shell variables.
    if ! git show ":$path" 2>/dev/null > "$TMPFILE"; then
        continue
    fi

    if [ "$path" = ".codex/config.toml" ] && \
        grep -a -E -n '^\[(projects\.|hooks\.state(\]|\.)|marketplaces\.)' "$TMPFILE" >/dev/null; then
        echo "[secret-check] blocked machine-local Codex state in: $path"
        echo "Run ./install.sh (macOS) or ./install.ps1 (Windows) to enable the clean filter."
        violations=1
        continue
    fi

    ignore_filtered="${TMPFILE}.filtered"
    ignore_next=0
    while IFS= read -r line || [ -n "$line" ]; do
        if [ "$ignore_next" -eq 1 ]; then
            ignore_next=0
            continue
        fi

        case "$line" in
            *"$IGNORE_NEXT_LINE_MARKER"*)
                ignore_next=1
                continue
                ;;
            *"$IGNORE_LINE_MARKER"*)
                continue
                ;;
        esac

        printf '%s\n' "$line"
    done < "$TMPFILE" > "$ignore_filtered"
    mv "$ignore_filtered" "$TMPFILE"

    if grep -a -E -i -n -- "$SENSITIVE_CONTENT_PATTERN" "$TMPFILE" >/dev/null; then
        echo "[secret-check] blocked by content pattern in: $path"
        grep -a -E -i -n -- "$SENSITIVE_CONTENT_PATTERN" "$TMPFILE" | head -n 3
        violations=1
    fi
done <<< "$STAGED_FILES"

if [ "$violations" -ne 0 ]; then
    echo ""
    echo "[secret-check] result: BLOCKED"
    echo "Commit blocked: potential sensitive data detected in staged changes."
    echo "Fix the files or unstage them, then commit again."
    exit 1
fi

echo "[secret-check] result: PASS"

exit 0
